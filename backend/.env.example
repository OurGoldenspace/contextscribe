# Copy this file to .env and fill in your real values.
# Never commit .env to git — it's already in .gitignore.

# Get this from https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Get this from MongoDB Atlas -> Connect -> Drivers
# Replace <username> and <password> with your database user credentials
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/contextscribe?retryWrites=true&w=majority

# Local dev port (Render/Railway will set their own PORT automatically in production)
PORT=4000
